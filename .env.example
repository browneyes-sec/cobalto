# =============================================================================
# Cobalto SOC/MDR Platform — Environment Configuration
# =============================================================================

# --- Wazuh SIEM ---
WAZUH_MANAGER_HOST=wazuh-manager.wazuh.svc.cluster.local
WAZUH_MANAGER_PORT=1514
WAZUH_API_HOST=wazuh-manager.wazuh.svc.cluster.local
WAZUH_API_PORT=55000
WAZUH_API_USER=admin
WAZUH_API_PASSWORD=changeme

# --- ElasticSearch / OpenSearch ---
ELASTICSEARCH_HOST=elasticsearch.elasticsearch.svc.cluster.local
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_SCHEME=https

# --- Qdrant Vector Store ---
QDRANT_URL=http://qdrant.qdrant.svc.cluster.local:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=mitre_attack
QDRANT_VECTOR_SIZE=1536

# --- OpenCTI Threat Intelligence ---
OPENCTI_URL=http://opencti.opencti.svc.cluster.local:4000
OPENCTI_API_KEY=changeme

# --- Cortex Analyzer ---
CORTEX_URL=http://cortex.cortex.svc.cluster.local:9001
CORTEX_API_KEY=changeme
CORTEX_ORG_ID=changeme

# --- TheHive SOAR ---
THEHIVE_URL=http://thehive.thehive.svc.cluster.local:9000
THEHIVE_API_KEY=changeme

# --- LangGraph Agent ---
LANGGRAPH_HOST=0.0.0.0
LANGGRAPH_PORT=8000
LANGGRAPH_WORKERS=4
OPENAI_API_KEY=sk-changeme
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- n8n Workflow Automation ---
N8N_HOST=n8n.n8n.svc.cluster.local
N8N_PORT=5678
N8N_WEBHOOK_URL=https://n8n.example.com/webhook
N8N_API_KEY=changeme

# --- Vault Secrets ---
VAULT_ADDR=http://vault.vault.svc.cluster.local:8200
VAULT_TOKEN=changeme
VAULT_UNSEAL_KEY_1=
VAULT_UNSEAL_KEY_2=
VAULT_UNSEAL_KEY_3=

# --- Grafana Observability ---
GRAFANA_HOST=grafana.grafana.svc.cluster.local
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_API_KEY=changeme

# --- Prometheus ---
PROMETHEUS_HOST=prometheus.monitoring.svc.cluster.local
PROMETHEUS_PORT=9090

# --- Alert Routing ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/changeme
PAGERDUTY_ROUTING_KEY=changeme
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=changeme
ALERT_FROM_EMAIL=cobalto-alerts@example.com

# --- SOC Operations ---
SOC_PRIMARY_ANALYST_EMAIL=soc-lead@example.com
SOC_ESCALATION_EMAIL=soc-escalation@example.com
SOC_TICKETING_SYSTEM=thehive
INCIDENT_RETENTION_DAYS=90

# --- Deployment ---
KUBERNETES_NAMESPACE=cobalto
DOCKER_REGISTRY=your-account.dkr.ecr.region.amazonaws.com
IMAGE_TAG=latest
ENVIRONMENT=production
