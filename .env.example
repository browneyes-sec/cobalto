# =============================================================================
# COBALTO ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit the actual .env file to version control

# =============================================================================
# APPLICATION
# =============================================================================
APP_ENV=development
APP_NAME=cobalto
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql+asyncpg://cobalto:cobalto_local_dev@localhost:5432/cobalto
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# WAZUH SIEM
# =============================================================================
WAZUH_URL=https://localhost:55000
WAZUH_USERNAME=wazuh
WAZUH_PASSWORD=admin
WAZUH_VERIFY_SSL=false

# =============================================================================
# OPENCTI THREAT INTEL
# =============================================================================
OPENCTI_URL=http://localhost:4000/graphql
OPENCTI_TOKEN=d41d8cd98f00b204e9800998ecf8427e

# =============================================================================
# THEHIVE CASE MANAGEMENT
# =============================================================================
THEHIVE_URL=http://localhost:9000/api
THEHIVE_TOKEN=change-me

# =============================================================================
# CORTEX ENRICHMENT
# =============================================================================
CORTEX_URL=http://localhost:9001/api
CORTEX_TOKEN=change-me

# =============================================================================
# N8N SOAR
# =============================================================================
N8N_URL=http://localhost:5678
N8N_API_KEY=change-me
N8N_WEBHOOK_SECRET=change-me

# =============================================================================
# LANGGRAPH AGENT SERVICE
# =============================================================================
LANGGRAPH_URL=http://localhost:8001
LANGGRAPH_API_KEY=change-me

# =============================================================================
# VECTOR DATABASE
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# ELASTICSEARCH
# =============================================================================
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# =============================================================================
# VAULT
# =============================================================================
VAULT_URL=http://localhost:8200
VAULT_TOKEN=root
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# SLACK
# =============================================================================
SLACK_BOT_TOKEN=xoxb-change-me
SLACK_SIGNING_SECRET=change-me
SLACK_CHANNEL_ALERTS=#soc-alerts
SLACK_CHANNEL_APPROVALS=#soc-approvals

# =============================================================================
# EXTERNAL APIs
# =============================================================================
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=

# =============================================================================
# AWS
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_MITRE_MAPPING=true
ENABLE_THREAT_HUNT=false
ENABLE_DOCUMENTATION_AGENT=false
ENABLE_AUTO_RESPONSE=false
ENABLE_MULTI_TENANT=false

# =============================================================================
# MONITORING
# =============================================================================
PROMETHEUS_PORT=9090
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# =============================================================================
# OPENTELEMETRY
# =============================================================================
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=cobalto
OTEL_SAMPLE_RATE=0.1