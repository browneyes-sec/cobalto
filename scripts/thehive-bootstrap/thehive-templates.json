{
  "templates": [
    {
      "name": "Brute Force Investigation",
      "title": "Brute Force Investigation - {{source}}",
      "description": "Investigation of brute force attack targeting SSH/RDP services. Multiple failed authentication attempts detected from source IP {{source}}.",
      "severity": "high",
      "tags": ["brute-force", "credential-access", "T1110.001", "soc-playbook"],
      "tlp": "TLP:AMBER",
      "pap": "TLP:AMBER",
      "customFields": [
        {
          "name": "mitre_technique",
          "value": "T1110.001 - Brute Force: Password Guessing"
        },
        {
          "name": "detection_source",
          "value": "Wazuh SIEM"
        },
        {
          "name": "incident_severity",
          "value": "High"
        },
        {
          "name": "source_ip",
          "value": "{{source}}"
        },
        {
          "name": "affected_assets",
          "value": "{{target}}"
        },
        {
          "name": "false_positive_assessment",
          "value": "Requires validation"
        }
      ],
      "tasks": [
        {
          "title": "Validate alert is not false positive",
          "group": "SOC Analyst"
        },
        {
          "title": "Review failed authentication logs",
          "group": "SOC Analyst"
        },
        {
          "title": "Check if credentials have been compromised",
          "group": "SOC Analyst"
        },
        {
          "title": "Block source IP if confirmed malicious",
          "group": "SOC Analyst"
        },
        {
          "title": "Notify affected account owners",
          "group": "SOC Analyst"
        },
        {
          "title": "Force password reset for targeted accounts",
          "group": "Senior Analyst"
        }
      ],
      "observables": []
    },
    {
      "name": "Malware Detection",
      "title": "Malware Detection - {{malware_name}}",
      "description": "Malware detected on endpoint {{host}}. File hash: {{hash}}. Malware classified as {{malware_type}}. Immediate investigation required.",
      "severity": "critical",
      "tags": ["malware", "execution", "T1059", "soc-playbook"],
      "tlp": "TLP:RED",
      "pap": "TLP:RED",
      "customFields": [
        {
          "name": "mitre_technique",
          "value": "T1059 - Command and Scripting Interpreter"
        },
        {
          "name": "detection_source",
          "value": "EDR / Antivirus"
        },
        {
          "name": "incident_severity",
          "value": "Critical"
        },
        {
          "name": "affected_assets",
          "value": "{{host}}"
        },
        {
          "name": "malware_family",
          "value": "{{malware_name}}"
        },
        {
          "name": "file_hash",
          "value": "{{hash}}"
        },
        {
          "name": "false_positive_assessment",
          "value": "Requires validation"
        }
      ],
      "tasks": [
        {
          "title": "Isolate affected endpoint from network",
          "group": "SOC Analyst"
        },
        {
          "title": "Submit file hash to VirusTotal for analysis",
          "group": "SOC Analyst"
        },
        {
          "title": "Check for lateral movement indicators",
          "group": "SOC Analyst"
        },
        {
          "title": "Collect forensic artifacts from endpoint",
          "group": "Senior Analyst"
        },
        {
          "title": "Update IOCs in threat intelligence platform",
          "group": "SOC Analyst"
        },
        {
          "title": "Reimage compromised endpoint",
          "group": "Senior Analyst"
        }
      ],
      "observables": [
        {
          "dataType": "hash",
          "data": "{{hash}}"
        }
      ]
    },
    {
      "name": "Phishing Campaign",
      "title": "Phishing Campaign - {{campaign_name}}",
      "description": "Phishing campaign detected targeting multiple users. Campaign name: {{campaign_name}}. {{affected_users}} users reported or clicked malicious links. Immediate containment required.",
      "severity": "high",
      "tags": ["phishing", "initial-access", "T1566", "soc-playbook"],
      "tlp": "TLP:AMBER",
      "pap": "TLP:AMBER",
      "customFields": [
        {
          "name": "mitre_technique",
          "value": "T1566 - Phishing"
        },
        {
          "name": "detection_source",
          "value": "Email Gateway / User Report"
        },
        {
          "name": "incident_severity",
          "value": "High"
        },
        {
          "name": "affected_assets",
          "value": "{{affected_users}}"
        },
        {
          "name": "phishing_url",
          "value": "{{phishing_url}}"
        },
        {
          "name": "sender_email",
          "value": "{{sender}}"
        },
        {
          "name": "false_positive_assessment",
          "value": "Confirmed malicious"
        }
      ],
      "tasks": [
        {
          "title": "Block phishing URL and domain",
          "group": "SOC Analyst"
        },
        {
          "title": "Quarantine all instances of phishing email",
          "group": "SOC Analyst"
        },
        {
          "title": "Identify all users who clicked/opened",
          "group": "SOC Analyst"
        },
        {
          "title": "Reset passwords for affected users",
          "group": "SOC Analyst"
        },
        {
          "title": "Check for credential harvesting results",
          "group": "Senior Analyst"
        },
        {
          "title": "Send organization-wide phishing alert",
          "group": "Senior Analyst"
        }
      ],
      "observables": [
        {
          "dataType": "url",
          "data": "{{phishing_url}}"
        },
        {
          "dataType": "mail",
          "data": "{{sender}}"
        }
      ]
    },
    {
      "name": "Insider Threat",
      "title": "Insider Threat Investigation - {{user}}",
      "description": "Suspicious activity detected from internal user {{user}}. Activity includes {{activity_type}}. Insider threat investigation initiated.",
      "severity": "critical",
      "tags": ["insider-threat", "credential-access", "T1078", "soc-playbook"],
      "tlp": "TLP:RED",
      "pap": "TLP:RED",
      "customFields": [
        {
          "name": "mitre_technique",
          "value": "T1078 - Valid Accounts"
        },
        {
          "name": "detection_source",
          "value": "UEBA / SIEM"
        },
        {
          "name": "incident_severity",
          "value": "Critical"
        },
        {
          "name": "affected_assets",
          "value": "{{user}}"
        },
        {
          "name": "activity_description",
          "value": "{{activity_type}}"
        },
        {
          "name": "data_access_level",
          "value": "{{access_level}}"
        },
        {
          "name": "false_positive_assessment",
          "value": "Requires HR coordination"
        }
      ],
      "tasks": [
        {
          "title": "Preserve all user activity logs",
          "group": "SOC Analyst"
        },
        {
          "title": "Review user access permissions",
          "group": "SOC Analyst"
        },
        {
          "title": "Coordinate with HR and Legal",
          "group": "Senior Analyst"
        },
        {
          "title": "Monitor all user sessions in real-time",
          "group": "SOC Analyst"
        },
        {
          "title": "Disable user account pending investigation",
          "group": "Senior Analyst"
        },
        {
          "title": "Conduct full forensic analysis",
          "group": "Admin"
        }
      ],
      "observables": []
    },
    {
      "name": "Cloud Security Incident",
      "title": "Cloud Security Incident - {{cloud_provider}}",
      "description": "Cloud security incident detected on {{cloud_provider}} environment. Service: {{service}}. Incident type: {{incident_type}}. Immediate cloud security response required.",
      "severity": "high",
      "tags": ["cloud", "defense-evasion", "T1562.008", "soc-playbook"],
      "tlp": "TLP:AMBER",
      "pap": "TLP:AMBER",
      "customFields": [
        {
          "name": "mitre_technique",
          "value": "T1562.008 - Impair Defenses: Modify Cloud Logging"
        },
        {
          "name": "detection_source",
          "value": "CloudTrail / CSPM"
        },
        {
          "name": "incident_severity",
          "value": "High"
        },
        {
          "name": "cloud_provider",
          "value": "{{cloud_provider}}"
        },
        {
          "name": "affected_assets",
          "value": "{{service}}"
        },
        {
          "name": "cloud_account_id",
          "value": "{{account_id}}"
        },
        {
          "name": "false_positive_assessment",
          "value": "Requires validation"
        }
      ],
      "tasks": [
        {
          "title": "Verify CloudTrail / logging status",
          "group": "SOC Analyst"
        },
        {
          "title": "Review IAM policies for unauthorized changes",
          "group": "SOC Analyst"
        },
        {
          "title": "Check for exposed access keys",
          "group": "SOC Analyst"
        },
        {
          "title": "Revoke compromised credentials",
          "group": "Senior Analyst"
        },
        {
          "title": "Enable enhanced monitoring on affected services",
          "group": "SOC Analyst"
        },
        {
          "title": "Document cloud security posture improvements",
          "group": "Senior Analyst"
        }
      ],
      "observables": []
    }
  ]
}
